# ChartSearchAI configuration for the cloud VM (rsync'd to the GCE VM by cloud-sync).
#
# Copy to .env.chartsearch.cloud and edit:
#   cp .env.chartsearch.cloud.example .env.chartsearch.cloud
#   $EDITOR .env.chartsearch.cloud
#
# This file is rsync'd to the VM by cloud-sync (it's the one .env.* that
# IS included in the sync — local .env / .env.chartsearch stay on your laptop).
# .env.chartsearch.cloud is .gitignored — never commit real keys.

# --- Backend DB pointer ---
# `openmrs` is canonical: the 5,284-patient corpus is promoted into it (the staging
# schema `openmrs_test` is dropped post-promotion). `make cloud-seed` restores the
# local `openmrs` corpus into the VM's `openmrs` schema. The backend uses `openmrs`.
OMRS_DB_NAME=openmrs

# --- Image tag for frontend + gateway ---
# Same as local: `nightly-chartsearch` ships the AI sparkle ESM. Backend stays
# on the default 3.6.0 line; the chartsearchai .omod is rsync'd from local.
OPENMRS_REFAPP_TAG=nightly-chartsearch

# --- LLM endpoint ---
# Default: VM-side llmster (headless LM Studio) listening on :1234 and
# forwarding inference to your Mac over LM Link. See docs/cloud-deploy.md
# for the one-time `lms login` + `lms link enable` + `lms server start`
# bootstrap. Container reaches the VM host via host.docker.internal.
CHARTSEARCH_REMOTE_ENDPOINT_URL=http://host.docker.internal:1234/v1/chat/completions

# Model identifier — must match an id from `lms ps` on your Mac (LM Link
# makes those models visible to the VM as if they were local).
CHARTSEARCH_REMOTE_MODEL_NAME=gemma-4-e2b-it

# API key. LM Studio doesn't enforce auth; leave empty for the LM Link path.
# For cloud providers, set the real key here.
CHARTSEARCH_REMOTE_API_KEY=

# --- Engine ---
CHARTSEARCH_LLM_ENGINE=remote

# --- Querystore backend (mysql|lucene|elasticsearch) ---
# Default elasticsearch: the harness validates the real CQRS read store — a
# separate service, off the clinical DB. cloud-up starts the ES service and
# wires querystore at it. Set lucene (on-disk, single-host) or mysql (in core's
# DB; not real CQRS separation) to bring up those tiers instead.
CHARTSEARCH_QUERYSTORE_BACKEND=elasticsearch

# --- Proxy / TLS ---
# Cloud bring-up publishes Caddy on the real public 80 + 443 (vs local's 8088).
# CADDY_SITE switches the Caddyfile from the ":80" catch-all (local) to a real
# domain so Caddy auto-provisions a Let's Encrypt cert on first request.
# CADDY_EMAIL must be set when CADDY_AUTO_HTTPS=on — Let's Encrypt uses it for
# expiry warnings.
HARNESS_PROXY_HTTP_PORT=80
HARNESS_PROXY_HTTPS_PORT=443
CADDY_SITE=your-domain.example
# Optional subdomain that serves the SPA at its bare root (transparent rewrite
# to /openmrs/spa/). Cleaner demo URL than the legacy /openmrs/spa path.
# Leave commented out if you don't want the subdomain; it'll stay dormant.
#CADDY_SITE_OPENMRS=openmrs.your-domain.example
# Optional subdomain serving published validation reports (static files). Dormant if commented out.
#CADDY_SITE_REPORTS=reports.your-domain.example
CADDY_EMAIL=you@example.com

# --- Alternative: cloud LLM directly (no LM Link, no Mac dependency) ---
#
# Anthropic OpenAI-compat:
#   CHARTSEARCH_REMOTE_ENDPOINT_URL=https://api.anthropic.com/v1/chat/completions
#   CHARTSEARCH_REMOTE_MODEL_NAME=claude-haiku-4-5
#   CHARTSEARCH_REMOTE_API_KEY=sk-ant-...
#
# OpenAI:
#   CHARTSEARCH_REMOTE_ENDPOINT_URL=https://api.openai.com/v1/chat/completions
#   CHARTSEARCH_REMOTE_MODEL_NAME=gpt-4o-mini
#   CHARTSEARCH_REMOTE_API_KEY=sk-...
