# med-agent-hub ("Med Agent Team") configuration for the harness
#
# Copy to .env.med-agent-hub and edit:
#   cp .env.med-agent-hub.example .env.med-agent-hub
#   $EDITOR .env.med-agent-hub
#
# Source before running compose / make (the compose service reads these via
# ${VAR:-default} substitution):
#   set -a; . .env.med-agent-hub; set +a
#
# .env.med-agent-hub is .gitignored. All vars are OPTIONAL — the compose
# defaults below work out of the box against a local LM Studio.

# --- LLM endpoint the team calls ---
# Local: the host's LM Studio (or any OpenAI-compat server) via host.docker.internal.
# Cloud: point at the LM Link tunnel address the VM uses (see .env.chartsearch.cloud).
MED_AGENT_LLM_BASE_URL=http://host.docker.internal:1234

# --- Team models (swappable per role) ---
# Orchestrator + synthesizer (one model, dual role). Use the official google/
# gemma-4 build — some community GGUFs (unsloth, e2b) ship a broken jinja tool
# template that 400s on tool-calling. llama-3.1-8b is a working fallback.
MED_AGENT_ORCHESTRATOR_MODEL=google/gemma-4-e4b
# Medical expert tool (free-text clinical reasoning).
MED_AGENT_MED_MODEL=medgemma-1.5-4b-it

# --- Decoding ---
MED_AGENT_TEMPERATURE=0.0
