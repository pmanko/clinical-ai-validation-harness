# ChartSearchAI configuration for the harness (feature 004 PoC)
#
# Copy to .env.chartsearch and edit:
#   cp .env.chartsearch.example .env.chartsearch
#   $EDITOR .env.chartsearch
#
# Source before running compose / make:
#   set -a; . .env.chartsearch; set +a
#
# .env.chartsearch is .gitignored — never commit real API keys.

# --- Backend DB pointer ---
# `openmrs_test` is the transformed 5,284-patient corpus from feature 002.
# `openmrs` is the CIEL canvas baseline (~50 patients).
OMRS_DB_NAME=openmrs_test

# --- Image tag for frontend + gateway ---
# `nightly-chartsearch` published images include the @openmrs/esm-chartsearchai-app
# ESM baked into the SPA bundle (sparkle button + chat panel UI). Backend image
# is independent — it stays on the OPENMRS_REFAPP_TAG default unless overridden
# elsewhere. The chartsearchai .omod dropped into artifacts/openmrs/modules/
# loads on top of whatever backend version is running.
OPENMRS_REFAPP_TAG=nightly-chartsearch

# --- LLM endpoint ---
# Default: LM Studio running on the host. Steps to enable:
#   1. LM Studio GUI → Developer tab → Server Settings → enable "Serve on Local Network"
#      (or run `lms server start --bind 0.0.0.0` for headless / CLI mode)
#   2. Load at least one model AND bump its **Context Length** to >=32768 (32K).
#      LM Studio's default loaded context is 4096 — too small for chartsearchai's
#      full-chart prompt (a rich patient like Zabella Halambe serializes to
#      ~20-40K tokens). With 4K context, requests hang or fail silently.
#      Bump in the model's load settings before loading, or eject + reload.
#   3. Confirm the model is visible:  curl -s http://localhost:1234/v1/models | jq -r '.data[].id'
#   4. From inside the chartsearch backend container, the URL is host.docker.internal:1234
#      (Mac/Win) — or your host's LAN IP if Docker Desktop bridging is funky.
CHARTSEARCH_REMOTE_ENDPOINT_URL=http://host.docker.internal:1234/v1/chat/completions

# Model identifier to send in each chat-completion request. Must match an
# identifier from LM Studio's /v1/models endpoint. Leave empty to let
# `make chartsearch-configure` auto-pick the first model LM Studio reports.
CHARTSEARCH_REMOTE_MODEL_NAME=

# API key. LM Studio doesn't enforce auth by default — leave empty.
# For cloud providers (Anthropic / OpenAI / etc.), set the real key here.
CHARTSEARCH_REMOTE_API_KEY=

# --- Engine ---
# `remote` is the only mode wired in this PoC. `local` (bundled llama-server)
# is out of scope; see specs/004-real-adapter-entrypoints/plan.md §D3.
CHARTSEARCH_LLM_ENGINE=remote

# --- Warmup (LM Studio only) ---
# Pre-load these models via `lms load -c $CTX` and write persistent
# per-model defaults so future JIT-reloads don't revert to LM Studio's
# default 4096-token context. Run `make chartsearch-warmup` after compose up.
# Comma-separated. If unset, falls back to just CHARTSEARCH_REMOTE_MODEL_NAME.
CHARTSEARCH_WARMUP_MODELS=gemma-4-e2b-it,unsloth/gemma-4-e4b-it,meta-llama-3.1-8b-instruct
# Context length to set on all warmed-up models. 32768 = covers Zabella-class
# rich charts with headroom. Models' max varies (e2b/e4b: 131072, llama-3.1: 131072).
CHARTSEARCH_CONTEXT_LENGTH=32768

# --- Alternative endpoint examples (uncomment + set CHARTSEARCH_REMOTE_API_KEY) ---
#
# Anthropic OpenAI-compat:
#   CHARTSEARCH_REMOTE_ENDPOINT_URL=https://api.anthropic.com/v1/chat/completions
#   CHARTSEARCH_REMOTE_MODEL_NAME=claude-haiku-4-5
#   CHARTSEARCH_REMOTE_API_KEY=sk-ant-...
#
# OpenAI:
#   CHARTSEARCH_REMOTE_ENDPOINT_URL=https://api.openai.com/v1/chat/completions
#   CHARTSEARCH_REMOTE_MODEL_NAME=gpt-4o-mini
#   CHARTSEARCH_REMOTE_API_KEY=sk-...
#
# Self-hosted Ollama on host:
#   CHARTSEARCH_REMOTE_ENDPOINT_URL=http://host.docker.internal:11434/v1/chat/completions
#   CHARTSEARCH_REMOTE_MODEL_NAME=llama3.3
#   CHARTSEARCH_REMOTE_API_KEY=
