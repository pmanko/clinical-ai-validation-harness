# ChartSearchAI configuration for the harness (feature 004 PoC)
#
# Copy to .env.chartsearch and edit:
#   cp .env.chartsearch.example .env.chartsearch
#   $EDITOR .env.chartsearch
#
# Source before running compose / make:
#   set -a; . .env.chartsearch; set +a
#
# .env.chartsearch is .gitignored — never commit real API keys.

# --- Backend DB pointer ---
# `openmrs` is canonical: feature 002's transformed 5,284-patient corpus, promoted
# into it. The staging schema `openmrs_test` (the dlt load target) is dropped after
# promotion — the backend connects to `openmrs` only.
OMRS_DB_NAME=openmrs

# --- Image tag for frontend + gateway ---
# `nightly-chartsearch` published images include the @openmrs/esm-chartsearchai-app
# ESM baked into the SPA bundle (sparkle button + chat panel UI). Backend image
# is independent — it stays on the OPENMRS_REFAPP_TAG default unless overridden
# elsewhere. The chartsearchai .omod dropped into artifacts/openmrs/modules/
# loads on top of whatever backend version is running.
OPENMRS_REFAPP_TAG=nightly-chartsearch

# --- LLM endpoint ---
# CANONICAL path: chartsearchai -> Med Agent Hub (:8080) -> llama-router (:8077).
# The hub runs the in-process agent team and returns chartsearchai's strict
# {answer,citations,blocks} envelope; its per-role models are served by the
# canonical local backend, a llama.cpp Router Mode server on :8077 (GGUF + DRY).
# Bring the backend up with `make llama-router-up`, then `make med-agent-hub-up`.
#
# The endpointUrl is resolved by the OpenMRS BACKEND container (it makes the
# inference call), which reaches the hub on the docker network as `med-agent-hub`.
CHARTSEARCH_REMOTE_ENDPOINT_URL=http://med-agent-hub:8080/v1/chat/completions

# Hub team preset to request. `med-agent-team-med-validated` = the MED tier with a
# competent validator (drives the per-section confidence chips in the chat panel).
# Other presets live in targets/med-agent-hub/server/levels.yaml (…-low / -med /
# -high, each with a -validated variant). MUST be set explicitly for the hub path:
# the host can't resolve `med-agent-hub` to auto-discover a model.
CHARTSEARCH_REMOTE_MODEL_NAME=med-agent-team-med-validated

# Picker endpoint registry. JSON array of {label,url} for the chat picker's
# per-endpoint sections; models are probed live from each endpoint's /v1/models.
# Default below exposes the canonical Med Agent Hub plus the raw llama-router and
# LM Studio as configurable alternatives. SINGLE-QUOTE so the shell preserves the
# inner double quotes. Unset -> single section from CHARTSEARCH_REMOTE_ENDPOINT_URL.
CHARTSEARCH_REMOTE_ENDPOINTS='[{"label":"Med Agent Hub","url":"http://med-agent-hub:8080/v1/chat/completions"},{"label":"llama-server","url":"http://host.docker.internal:8077/v1/chat/completions"},{"label":"LM Studio","url":"http://host.docker.internal:1234/v1/chat/completions"}]'

# API key. The local hub / llama-router / LM Studio don't enforce auth — leave
# empty. For cloud providers (Anthropic / OpenAI / etc.), set the real key here.
CHARTSEARCH_REMOTE_API_KEY=

# --- Alternative: LM Studio directly (configurable, NOT the default path) ---
# To drive LM Studio instead of the hub, point the endpoint at :1234 and pick a
# loaded model. Steps:
#   1. LM Studio GUI → Developer → Server Settings → enable "Serve on Local Network"
#      (or `lms server start --bind 0.0.0.0` for headless / CLI mode).
#   2. Load a model AND bump its Context Length to >=32768 — LM Studio's default
#      4096 is too small for chartsearchai's full-chart prompt (~20-40K tokens).
#   3. Confirm:  curl -s http://localhost:1234/v1/models | jq -r '.data[].id'
#   CHARTSEARCH_REMOTE_ENDPOINT_URL=http://host.docker.internal:1234/v1/chat/completions
#   CHARTSEARCH_REMOTE_MODEL_NAME=        # empty -> auto-pick the first loaded model

# --- Engine ---
# `remote` (default) drives an OpenAI-compatible endpoint (the canonical Med Agent
# Hub -> llama-router path, or LM Studio / cloud as alternatives). `local` runs
# chartsearchai's OWN bundled llama-server in-process on the backend — the module
# out-of-the-box shape. Flip with `make chartsearch-engine ENGINE=local|remote`;
# local triggers a ~5GB GGUF download on the backend.
CHARTSEARCH_LLM_ENGINE=remote
# GGUF the local engine loads (path relative to /openmrs/data; downloaded by
# backend-init.sh, set as chartsearchai.llm.modelFilePath). Default = the Q4_K_M
# build of gemma-4-E4B, the same family as the remote default.
CHARTSEARCH_LOCAL_MODEL_FILE=chartsearchai/gemma-4-E4B-it-Q4_K_M.gguf

# --- Warmup (LM Studio only, optional) ---
# Pre-load these models via `make chartsearch-warmup` after compose up to avoid a
# cold-start on the first request. PREFERRED context fix: set LM Studio's global
# "Default Context Length" (Settings) to model-max (or >= 32768) so every JIT load
# comes up at a sane context — then warmup is purely a latency optimization and the
# per-model context dance is unnecessary. The stack uses just two models:
# google/gemma-4-e4b (gemma backend + team orchestrator — the tool-capable Gemma 4)
# and medgemma-1.5-4b-it (medgemma backend + team expert).
CHARTSEARCH_WARMUP_MODELS=google/gemma-4-e4b,medgemma-1.5-4b-it
# Context length to set on all warmed-up models. 32768 = covers Zabella-class
# rich charts with headroom. Models' max varies (e2b/e4b: 131072, llama-3.1: 131072).
CHARTSEARCH_CONTEXT_LENGTH=32768
# Idle seconds before LM Studio auto-unloads a warmed model (frees RAM for JIT
# loads of other models; the timer resets on each request, so a model in active
# use stays warm). Default 3600 (1h). Set 0 to pin warmed models until restart.
# LM Studio does NOT evict explicitly-loaded models under memory pressure — only
# this idle-TTL unload — so the warmed base set + the largest model you JIT-load
# must still fit in RAM together.
CHARTSEARCH_WARMUP_TTL=3600

# --- Alternative endpoint examples (uncomment + set CHARTSEARCH_REMOTE_API_KEY) ---
#
# Anthropic OpenAI-compat:
#   CHARTSEARCH_REMOTE_ENDPOINT_URL=https://api.anthropic.com/v1/chat/completions
#   CHARTSEARCH_REMOTE_MODEL_NAME=claude-haiku-4-5
#   CHARTSEARCH_REMOTE_API_KEY=sk-ant-...
#
# OpenAI:
#   CHARTSEARCH_REMOTE_ENDPOINT_URL=https://api.openai.com/v1/chat/completions
#   CHARTSEARCH_REMOTE_MODEL_NAME=gpt-4o-mini
#   CHARTSEARCH_REMOTE_API_KEY=sk-...
#
# Self-hosted Ollama on host:
#   CHARTSEARCH_REMOTE_ENDPOINT_URL=http://host.docker.internal:11434/v1/chat/completions
#   CHARTSEARCH_REMOTE_MODEL_NAME=llama3.3
#   CHARTSEARCH_REMOTE_API_KEY=
