.DS_Store

# Python
.venv/
venv/
__pycache__/
**/__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Local configuration and generated run output
.env
.env.*
artifacts/**
!artifacts/
!artifacts/.gitkeep

# Source corpus files (large; checksum/provenance is committed under
# datasets/sources/<dataset>.checksum). Operators re-fetch the actual dump
# from its canonical origin and verify the checksum.
data/

# Pinned OCL collection exports (ZIPs are large; provenance.json is committed
# under datasets/sources/ocl/<collection>/<version>/ for re-fetch + integrity).
datasets/sources/ocl/**/*.zip

# FHIR Validator CLI binary (pulled at run time; version pin under VERSION file).
tools/fhir-validator/*.jar
