{
    # Caddy auto-enables TLS when the site address is a domain name; for a
    # port-only address like `:80` it stays plain HTTP. So local dev
    # (CADDY_SITE=":80") gets no TLS; cloud bring-up (CADDY_SITE="<domain>")
    # gets a Let's Encrypt cert automatically.
    admin off
    email {$CADDY_EMAIL:nobody@example.com}
    log {
        output stderr
        format console
    }
}

# Harness reverse proxy.
# All host-facing HTTP traffic comes through this server; internal services
# (gateway, backend, frontend, future chartsearchai-gateway, etc.) are not
# directly exposed on the host. Routing is path-based on a single port (or
# domain when running in cloud).
#
# Site address is env-driven:
#   CADDY_SITE unset (default)  -> ":80"   — local dev, any Host header
#   CADDY_SITE="openclinai.org" -> the domain, with auto-TLS via Let's Encrypt
#
# Add new services here as they join the stack (chartsearchai, querystore, etc.).

# Higher-priority handles that intercept SPA paths before the generic
# /openmrs/* gateway route. Used to swap in our harness-built ESM bundle
# without rebuilding the :nightly-chartsearch image: Caddy serves the
# regenerated importmap.json and the custom chartsearchai bundle dir
# from artifacts/openmrs/spa-custom (mounted into the proxy container
# at /srv/spa-custom), while the rest of /openmrs/* falls through to
# the gateway → frontend container as before.
#
# The custom importmap is fetched live from the running frontend
# container at build time and only the chartsearchai entry is rewritten,
# so unrelated module versions stay aligned with whatever upstream
# nightly the SPA shell expects.
(chartsearch_overrides) {
    handle /openmrs/spa/importmap.json {
        # `handle` matches but does NOT strip the URL prefix; `root` is a
        # filesystem path. `rewrite` re-targets the URL to the bare filename
        # before `file_server` resolves it relative to `root`.
        rewrite * /importmap.json
        root * /srv/spa-custom
        file_server
    }
    handle /openmrs/spa/routes.registry.json {
        # The OpenMRS app-shell reads this on boot to discover frontend modules
        # and their extensions/workspaces. The stock :3.6.0 frontend image
        # doesn't bake chartsearchai into the registry, so we serve an
        # overridden copy that adds the @openmrs/esm-chartsearchai-app entry.
        # Without this override the importmap alias is unused — the app-shell
        # never imports the bundle and the patient-banner extension never
        # mounts. The registry is what makes routes.json take effect.
        rewrite * /routes.registry.json
        root * /srv/spa-custom
        file_server
    }
    handle_path /openmrs/spa/openmrs-esm-chartsearchai-app-multiturn/* {
        # `handle_path` strips the matched prefix before passing to `file_server`,
        # so chunk URLs like `.../101.js` resolve to /srv/spa-custom/<bundle>/101.js.
        root * /srv/spa-custom/openmrs-esm-chartsearchai-app-multiturn
        file_server
    }
}

(openmrs_routes) {
    # 256 MB body limit is plenty for CIEL OCL exports (current ~60MB) plus headroom.
    request_body {
        max_size 256MB
    }

    # Large multipart POST uploads (OCL import ZIPs ~60MB) bypass the gateway's
    # nginx default client_max_body_size=1MB and go directly to backend Tomcat.
    # Restricted to POST so polling GETs (import status, item enumeration) keep
    # going through the gateway's normal routing (headers, gzip, etc.).
    @ocl_upload {
        method POST
        path /openmrs/ws/rest/v1/openconceptlab/import
    }
    handle @ocl_upload {
        reverse_proxy backend:8080
    }

    # chartsearchai chat turns can take minutes (HIGH tier cold-loads 19-29G GGUFs
    # one at a time and runs an orchestrator tool-loop). The gateway's nginx
    # proxy_read_timeout (60s default) returns 504 before the backend answers, so
    # these requests bypass the gateway and go straight to backend Tomcat, where
    # Caddy's reverse_proxy applies a generous read timeout instead.
    @chartsearch_chat {
        path /openmrs/ws/rest/v1/chartsearchai/*
    }
    handle @chartsearch_chat {
        reverse_proxy backend:8080 {
            transport http {
                read_timeout 1200s
                write_timeout 1200s
            }
        }
    }

    # OpenMRS RefApp (gateway is itself nginx that routes between backend + frontend)
    handle /openmrs/* {
        reverse_proxy gateway:80
    }

    # Health probe target for the proxy itself
    handle /__proxy_health {
        respond "ok" 200
    }
}

# Main site: legacy URL shape `<host>/openmrs/spa` (bare root redirects to it).
# Local dev uses ":80" catch-all; cloud sets CADDY_SITE="openclinai.org".
{$CADDY_SITE::80} {
    import chartsearch_overrides
    import openmrs_routes

    # Bare root: redirect to the OpenMRS SPA at its canonical path.
    handle / {
        redir /openmrs/spa 302
    }

    # Anything unrecognised: 404 with a hint
    handle {
        respond "harness proxy: no route configured for {http.request.uri.path}. See compose/Caddyfile." 404
    }
}

# OpenMRS subdomain: SPA at bare root (`<host>/`) via transparent rewrite to
# the gateway's /openmrs/spa/. /openmrs/* still works for REST/FHIR/legacy UI
# and /openmrs/spa direct still works for callers who already use that path.
# Default ":8090" is a port we don't publish, so the block is dormant on local
# dev (no Host-header match, no LE attempt); cloud sets the real subdomain.
{$CADDY_SITE_OPENMRS::8090} {
    import chartsearch_overrides
    import openmrs_routes

    # Bare root: serve the SPA index transparently (browser URL stays "/").
    # Subsequent SPA navigation will surface "/openmrs/spa/..." in the URL bar
    # because the SPA's internal links are absolute. Acceptable cost.
    handle / {
        rewrite * /openmrs/spa/
        reverse_proxy gateway:80
    }

    handle {
        respond "harness proxy: no route configured for {http.request.uri.path}. See compose/Caddyfile." 404
    }
}

# Reports subdomain: static-serve published validation reports from artifacts/reports (mounted at
# /srv/reports). Dormant locally on :8091 (unpublished — no Host match, no LE attempt); cloud sets
# CADDY_SITE_REPORTS=reports.<domain> for auto-TLS. `browse` gives a directory index of published runs.
{$CADDY_SITE_REPORTS::8091} {
    root * /srv/reports
    file_server browse
}
